# Variables de entorno para correr los tests automatizados (npm test / npm run test:integration).
# Apunta a una base de datos separada de la de desarrollo para que los tests
# nunca toquen datos reales — ver docs/backend/pendientes.md punto 5.
DB_HOST=localhost
DB_PORT=3306
DB_USER=dsw
DB_PASSWORD=dsw
DB_NAME=gestordetorneos_test

JWT_SECRET=clave-de-test-no-usar-en-produccion

# No se usan en los tests (no se ejercita el flujo de Google login ni el de
# mail de recuperación de contraseña), pero se documentan para que quede
# claro que quedaron sin valor a propósito.
GOOGLE_CLIENT_ID=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

FRONTEND_URL=http://localhost:5173
