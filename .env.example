# Conexión a MySQL. Para una base en la nube (ej. Aiven), completar con el
# host/puerto/usuario/contraseña que da el proveedor y poner DB_SSL=true
# (Aiven exige ssl-mode=REQUIRED). En desarrollo local, dejar DB_SSL=false.
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=changeme
DB_NAME=gestordetorneos
DB_SSL=false

JWT_SECRET=reemplazar-con-clave-secreta-larga

# Client ID de Google Cloud (OAuth) — verificación de id_token en /jugadores/google-login.
# El Client Secret NO hace falta para este flujo y no debe agregarse acá.
GOOGLE_CLIENT_ID=reemplazar-con-client-id-de-google-cloud.apps.googleusercontent.com

# Envío de mails de recuperación de contraseña (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=app-password-de-google
MAIL_FROM="Gestor de Torneos <tu-correo@gmail.com>"

# URL del frontend, usada para armar el link de recuperación de contraseña
FRONTEND_URL=http://localhost:5173
